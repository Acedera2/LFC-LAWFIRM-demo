{
  "name": "@lfc/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "dev:demo": "node dev-server.js",
    "start": "node src/index.js",
    "setup": "node scripts/setup-db.js",
    "lint": "eslint \"src/**/*.js\" --max-warnings=0",
    "prisma:generate": "prisma generate",
    "prisma:generate:safe": "node scripts/prisma-generate-safe.cjs",
    "prisma:migrate": "node scripts/wait-for-db.cjs && prisma migrate dev --name init",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "node scripts/wait-for-db.cjs && node prisma/seed.js",
    "prisma:generate:sqlite": "prisma generate --schema=prisma/schema.sqlite.prisma",
    "prisma:migrate:sqlite": "prisma migrate dev --schema=prisma/schema.sqlite.prisma --name init",
    "seed:sqlite": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "mysql2": "^3.12.0",
    "pdfkit": "^0.15.2",
    "zod": "^3.24.1"
    ,"cookie-parser": "^1.4.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "nodemon": "^3.1.9",
    "playwright": "^1.60.0",
    "prisma": "^6.1.0"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
