generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum LawyerStatus {
  ACTIVE
  ON_LEAVE
  INACTIVE
}

enum Priority {
  URGENT
  MODERATE
  REGULAR
}

enum AppointmentStatus {
  PENDING
  SCHEDULED
  APPROVED
  REJECTED
  RESCHEDULED
  CANCELLED
  COMPLETED
}

enum ConflictStatus {
  CLEAR
  WARNING
  CONFLICT
}

enum LocationMode {
  IN_PERSON
  PHONE
  FIELD
}

enum AvailabilityType {
  AVAILABLE
  UNAVAILABLE
  RESERVED
}

model Role {
  id    String @id @default(cuid()) @db.VarChar(32)
  slug  String @unique @db.VarChar(40)
  name  String @db.VarChar(80)
  users User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("roles")
}

model User {
  id           String   @id @default(cuid()) @db.VarChar(32)
  roleId       String   @db.VarChar(32)
  name         String   @db.VarChar(120)
  email        String   @unique @db.VarChar(160)
  passwordHash String   @db.VarChar(255)
  role         Role     @relation(fields: [roleId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clientProfile Client?
  lawyerProfile Lawyer?
  notifications Notification[]
  appointments  Appointment[] @relation("ClientAppointments")

  @@index([roleId])
  @@map("users")
}

model Client {
  id     String @id @default(cuid()) @db.VarChar(32)
  userId String @unique @db.VarChar(32)
  user   User   @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@map("clients")
}

model Lawyer {
  id             String       @id @default(cuid()) @db.VarChar(32)
  userId         String       @unique @db.VarChar(32)
  barNumber      String?      @db.VarChar(80)
  specialization String?      @db.VarChar(160)
  bio            String?      @db.Text
  status         LawyerStatus @default(ACTIVE)
  user           User         @relation(fields: [userId], references: [id])
  availability   Availability[]
  appointments   Appointment[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([status])
  @@map("lawyers")
}

model Appointment {
  id               String            @id @default(cuid()) @db.VarChar(32)
  clientId         String            @db.VarChar(32)
  lawyerId         String?           @db.VarChar(32)
  consultationType String            @db.VarChar(120)
  subject          String            @db.VarChar(180)
  description      String            @db.Text
  priority         Priority          @default(REGULAR)
  status           AppointmentStatus @default(PENDING)
  preferredStart   DateTime
  preferredEnd     DateTime
  scheduledStart   DateTime?
  scheduledEnd     DateTime?
  locationMode     LocationMode      @default(IN_PERSON)
  conflictStatus   ConflictStatus    @default(CLEAR)
  cancellationReason String?         @db.VarChar(500)
  rescheduleReason String?           @db.VarChar(500)

  client  User   @relation("ClientAppointments", fields: [clientId], references: [id])
  lawyer  Lawyer? @relation(fields: [lawyerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([lawyerId])
  @@index([status])
  @@index([priority])
  @@map("appointments")
}

model Availability {
  id        String           @id @default(cuid()) @db.VarChar(32)
  lawyerId  String           @db.VarChar(32)
  type      AvailabilityType @default(AVAILABLE)
  startsAt  DateTime
  endsAt    DateTime
  reason    String?          @db.VarChar(255)
  lawyer    Lawyer           @relation(fields: [lawyerId], references: [id])
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([lawyerId])
  @@index([startsAt, endsAt])
  @@map("lawyer_availability")
}

model Notification {
  id        String   @id @default(cuid()) @db.VarChar(32)
  userId    String   @db.VarChar(32)
  title     String   @db.VarChar(160)
  message   String   @db.VarChar(500)
  type      String   @db.VarChar(60)
  readAt    DateTime?
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([readAt])
  @@map("notifications")
}

model CancellationRequest {
  id            String   @id @default(cuid()) @db.VarChar(32)
  appointmentId String   @db.VarChar(32)
  requestedById String   @db.VarChar(32)
  reason        String?  @db.VarChar(500)
  status        String   @db.VarChar(32) @default("PENDING")
  createdAt     DateTime @default(now())

  @@index([appointmentId])
  @@index([requestedById])
  @@map("cancellation_requests")
}
