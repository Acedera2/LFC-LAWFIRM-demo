{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "lint workspace",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"lint"
			],
			"isBackground": false,
			"problemMatcher": [
				"$eslint-stylish"
			],
			"group": "build"
		},
		{
			"label": "lint workspace again",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"lint"
			],
			"isBackground": false,
			"problemMatcher": [
				"$eslint-stylish"
			],
			"group": "build"
		},
		{
			"label": "lint workspace final",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"lint"
			],
			"isBackground": false,
			"problemMatcher": [
				"$eslint-stylish"
			],
			"group": "build"
		},
		{
			"label": "build client",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build",
				"--workspace",
				"client"
			],
			"isBackground": false,
			"problemMatcher": [
				"$vite"
			],
			"group": "build"
		},
		{
			"label": "find port 5000",
			"type": "shell",
			"command": "netstat",
			"args": [
				"-ano",
				"|",
				"findstr",
				":5000"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "health check 5000",
			"type": "shell",
			"command": "curl",
			"args": [
				"-i",
				"http://localhost:5000/health"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "verify lint after setup fix",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"lint"
			],
			"isBackground": false,
			"problemMatcher": [
				"$eslint-stylish"
			],
			"group": "build"
		},
		{
			"label": "cleanup generated files",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"Remove-Item -Recurse -Force 'assets','client/dist','favicon.svg','hero-legal-suite.svg','index.html','lfc-logo.svg','cookies.txt'"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "delete stray files",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"Remove-Item -Force 'git','c.startsWith(''lfc_csrf'"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "delete brace artifact",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"Remove-Item -Force '{'"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "final lint check",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"lint"
			],
			"isBackground": false,
			"problemMatcher": [
				"$eslint-stylish"
			],
			"group": "build"
		}
		,
		{
			"label": "test:e2e client",
			"type": "shell",
			"command": "npm",
			"args": ["run", "test:e2e", "--workspace", "client"],
			"group": "test",
			"presentation": { "reveal": "always", "panel": "shared" }
		}
	]
}